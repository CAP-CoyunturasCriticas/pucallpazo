@article{somma_renovando_2022,
	title = {Renovando la arena política: estallido social, cambio constitucional y nuevo {Gobierno} en {Chile}},
	abstract = {This article analyzes the renewal process of the actors and ideas in Chile’s political arena during the last decade, focusing mainly on the last three years. The 2019 social uprising accelerated this incipient opening of the political arena by igniting a process of constitutional change currently underway. The uprising activated institutionally previously marginal actors and social movements and contributed to the victory of the current left-wing Government of Apruebo Dignidad, led by Gabriel Boric. Our analysis shows that the boundaries between institutional and non-institutional actors are more fluid than usually recognized and that this helps explain the renewal of Chile’s political arena during the last decade.},
	language = {es},

@article{levitsky_democracy_2003,
	title = {Democracy without {Parties}? {Political} {Parties} and {Regime} {Change} in {Fujimori}'s {Peru}},
	volume = {45},
	issn = {1531-426X, 1548-2456},
	shorttitle = {Democracy without {Parties}?},
	url = {https://www.cambridge.org/core/product/identifier/S1531426X00005069/type/journal_article},
	doi = {10.1111/j.1548-2456.2003.tb00248.x},
	abstract = {Abstract
            Political parties are critical to Latin American democracy. This was demonstrated in Peru, where an atomized, candidate-centered party system developed after Alberto Fujimori's 1992 presidential self-coup. Party system decomposition weakened the democratic opposition against an increasingly authoritarian regime. Since the regime collapsed in 2000, prospects for party rebuilding have been mixed. Structural changes, such as the growth of the informal sector and the spread of mass media technologies, have weakened politicians' incentive to build parties. Although these changes did not cause the collapse of the party system, they may inhibit its reconstruction.},
	language = {en},
	number = {03},
	urldate = {2025-06-30},
	journal = {Latin American Politics and Society},
	author = {Levitsky, Steven and Cameron, Maxwell A.},
	year = {2003},
	pages = {1--33},
}

@article{kitschelt_linkages_2000,
	title = {Linkages between {Citizens} and {Politicians} in {Democratic} {Polities}},
	volume = {33},
	copyright = {https://journals.sagepub.com/page/policies/text-and-data-mining-license},
	issn = {0010-4140, 1552-3829},
	url = {https://journals.sagepub.com/doi/10.1177/001041400003300607},
	doi = {10.1177/001041400003300607},
	abstract = {Research on democratic party competition in the formal spatial tradition of Downs and the comparative-historical tradition of Lipset and Rokkan assumes that linkages of accountability and responsiveness between voters and political elites work through politicians’ programmatic appeals and policy achievements. This ignores, however, alternative voter-elite linkages through the personal charisma of political leaders and, more important, selective material incentives in networks of direct exchange (clientelism). In light of the diversity of linkage mechanisms appearing in new democracies and changing linkages in established democracies, this article explores theories of linkage choice. It first develops conceptual definitions of charismatic, clientelist, and programmatic linkages between politicians and electoral constituencies. It then asks whether politicians face a trade-off or mutual reinforcement in employing linkage mechanisms. The core section of the article details developmentalist, statist, institutional, political-economic, and cultural-ideological theories of citizen-elite linkage formation in democracies, showing that none of the theories is fully encompassing. The final section considers empirical measurement problems in comparative research on linkage.},
	language = {en},
	number = {6-7},
	urldate = {2025-06-30},
	journal = {Comparative Political Studies},
	author = {Kitschelt, Herbert},
	month = sep,
	year = {2000},
	pages = {845--879},
}


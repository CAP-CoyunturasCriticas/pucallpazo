@article{hogan_critical_2019,
	title = {The {Critical} {Juncture} {Concept}’s {Evolving} {Capacity} to {Explain} {Policy} {Change}},
	volume = {5},
	issn = {2380-6567, 2380-6567},
	url = {https://onlinelibrary.wiley.com/doi/10.1002/epa2.1057},
	doi = {10.1002/epa2.1057},
	abstract = {This article examines the evolution of our understanding of the critical junctures concept. The concept ﬁnds its origins in historical intuitionalism, being employed in the context of path dependence to account for sudden and jarring institutional or policy changes. We argue that the concept and the literature surrounding it—now incorporating ideas, discourse, and agency—have gradually become more comprehensive and nuanced as historical institutionalism was followed by ideational historical institutionalism and constructivist and discursive institutionalism. The prime position of contingency has been supplanted by the role of ideas and agency in explaining critical junctures and other instances of less than transformative change. Consequently, the concept is now capable of providing more comprehensive explanations for policy change.},
	language = {en},
	number = {2},
	urldate = {2025-11-12},
	journal = {European Policy Analysis},
	author = {Hogan, John},
